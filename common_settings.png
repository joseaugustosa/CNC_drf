                                  <div class="progress-bar progress-bar-animated progress-bar-striped active" role="progressbar" style="width: 100%" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100">Please wait...</div>
                                </div>
                                <div class="row">
                                    <div class="col-sm-12 col-xs-12">
                                        <p>Your Order:</p>
                                    <table class="licence_table">
                                        <thead>
                                            <tr>
                                                <th style="width: 70%;">Product</th>
                                                <th>Price, USD</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr>
                                                <td>DrufelCNC FULL</td>
                                                <td>$198.00</td>
                                            </tr>
                                            <tr>
                                                <td class="subtotal_table">Subtotal</td>
                                                <td>$198.00</td>
                                            </tr>
                                                                                        <tr>
                                                <td class="subtotal_table">Total</td>
                                                <td><b><span id="price_total">$198.00 USD</span></b></td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                                    <div class="col-sm-6 col-xs-12">
                                        <p>Your Name:</p>
                                        <div class="form-group">
                                            <input type="text" class="form-control" name="name" id="name" placeholder="Full name" required>
                                        </div>
                                    </div>
                                    <div class="col-sm-6 col-xs-12">
                                        <p>Your Email:</p>
                                        <div class="form-group">
                                            <input type="email" class="form-control" name="email" id="email" placeholder="mail@gmail.com" required>
                                        </div>
                                    </div>
                                    <div class="col-sm-12 col-xs-12">
                                        <p>License Key:</p>
                                        <div class="form-group">
                                            <input type="text" class="form-control" name="lk" id="lk" placeholder="..." required>
                                        </div>
                                    </div>
                                    <label class="col-sm-6 col-xs-12">
                                        <p style="cursor: pointer;"><input type="checkbox" name="test" value="y" required>&nbsp;I have tested DrufelCNC</p>
                                    </label>
                                                                        <div class="span_license">
                                    <div class="col-sm-12 col-xs-12">
                                        <p>Choose a payment method <span>(Click one of the options below)</span></p>
                                    </div>
                                                                                                            <label class="col-sm-12 col-xs-12">
                                        <p style="cursor: pointer;" title="Cryptocurrency of the TRON network TRC20, USDT, USDC"><input type="radio" id="pay_tron" name="pay" value="tron" required>&nbsp;<img src="img/pay/tron.svg" style="max-width: 30px !important;" alt="">TRON,&nbsp;<img src="img/pay/tether.svg" style="max-width: 30px !important;" alt="">USDT TRC20,&nbsp;<img src="img/pay/usdcoin.svg" style="max-width: 30px !important;" alt="">USDC TRC20</p>
                                    </label>
                                    <label class="col-sm-12 col-xs-12">
                                        <p style="cursor: pointer;"  title="Cryptocurrency of the Ethereum network ERC20, USDT, USDC"><input type="radio" id="pay_eth" name="pay" value="eth" required>&nbsp;<img src="img/pay/eth.svg" style="max-width: 30px !important;" alt="">Ethereum,&nbsp;<img src="img/pay/tether.svg" style="max-width: 30px !important;" alt="">USDT ERC20,&nbsp;<img src="img/pay/usdcoin.svg" style="max-width: 30px !important;" alt="">USDC ERC20</p>
                                    </label>
                                    
                                    </div>
                                    
                                    <input type="hidden" name="sp" id="ssp">
                                    <div class="col-xs-12">
                                        <button name="button" class="button_lis" >SEND REQUEST</button>
                                        <span>*By click the button "SEND REQUEST" you agree to our <a href="?c=privacypolicy" target="_blank">Privacy Policy.</a></span>
                                    </div>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

<Window x:Class="CNC_Drf.Dialogs.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Width="730" Height="560"
        WindowStartupLocation="CenterOwner"
        Background="#f0f0f0" Foreground="#111"
        ResizeMode="CanResize" MinWidth="600" MinHeight="460">

    <Window.Resources>
        <!-- Estilos gerais Light theme -->
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#111"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="2,0"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#111"/>
            <Setter Property="BorderBrush" Value="#aaa"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="3,2"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#111"/>
            <Setter Property="BorderBrush" Value="#aaa"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Height" Value="24"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#111"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="#111"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="BorderBrush" Value="#bbb"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#111"/>
            <Setter Property="BorderBrush" Value="#ccc"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#e0e0e0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="RowHeight" Value="22"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="SelectionMode" Value="Single"/>
        </Style>

        <!-- Tab item com ícone grande + texto bold -->
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="#e0e0e0"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="#bbb" BorderThickness="1,1,1,0"
                                Margin="1,1,1,0" Padding="6,4">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="Icon" Text="{TemplateBinding Tag}"
                                           FontSize="22" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="{TemplateBinding Header}"
                                           VerticalAlignment="Center" FontSize="11"
                                           FontWeight="Bold"
                                           Foreground="{TemplateBinding Foreground}"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="White"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#888"/>
                                <Setter Property="Foreground" Value="#000"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#d0e8ff"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Botões Apply / Save / Cancel -->
        <Border DockPanel.Dock="Bottom" Background="#e8e8e8"
                BorderBrush="#bbb" BorderThickness="0,1,0,0" Padding="8,6">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Click="BtnApply_Click" Width="90" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✔" Foreground="#2e7d32" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Apply" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Click="BtnSave_Click" Width="90" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💾" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Save" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button IsCancel="True" Width="90">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✖" Foreground="#c62828" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Cancel" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- TabControl principal -->
        <TabControl Background="White" BorderBrush="#bbb" Padding="0">

            <!-- ═══════════ TAB: Common ═══════════ -->
            <TabItem Header="Common" Tag="⚙">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="White">
                    <StackPanel Margin="10">
                        <TextBlock Text="Common settings" FontSize="13" FontWeight="Bold" Margin="0,0,0,8" Foreground="#333"/>

                        <!-- TreeView / lista de portas por função -->
                        <Border BorderBrush="#ccc" BorderThickness="1">
                            <TreeView x:Name="CommonTree" Background="White" BorderThickness="0"
                                      FontSize="11" MinHeight="300">
                                <!-- Spindle -->
                                <TreeViewItem Header="Spindle Output Ports M3, M4, M5" IsExpanded="True"
                                              FontWeight="SemiBold">
                                    <TreeViewItem Header="" x:Name="TviSpindleOn">
                                        <TreeViewItem.HeaderTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="200"/>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="60"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="Turn the spindle" FontStyle="Italic"/>
                                                    <TextBox Grid.Column="1" x:Name="TbSpOn" Text="0" Margin="2,1" Height="20"/>
                                                    <CheckBox Grid.Column="2" x:Name="ChkSpOn" Margin="4,0"/>
                                                    <TextBlock Grid.Column="3" Text="M3, M4, M5" Foreground="#666"/>
                                                </Grid>
                                            </DataTemplate>
                                        </TreeViewItem.HeaderTemplate>
                                    </TreeViewItem>
                                    <TreeViewItem Header="">
                                        <TreeViewItem.HeaderTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="200"/>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="60"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="Spindle CW clockwise" FontStyle="Italic"/>
                                                    <TextBox Grid.Column="1" Text="1" Margin="2,1" Height="20"/>
                                                    <CheckBox Grid.Column="2" Margin="4,0"/>
                                                    <TextBlock Grid.Column="3" Text="M3" Foreground="#666"/>
                                                </Grid>
                                            </DataTemplate>
                                        </TreeViewItem.HeaderTemplate>
                                    </TreeViewItem>
                                    <TreeViewItem Header="">
                                        <TreeViewItem.HeaderTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="200"/>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="60"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="Spindle CCW counterclockwise" FontStyle="Italic"/>
                                                    <TextBox Grid.Column="1" Text="2" Margin="2,1" Height="20"/>
                                                    <CheckBox Grid.Column="2" Margin="4,0"/>
                                                    <TextBlock Grid.Column="3" Text="M4" Foreground="#666"/>
                                                </Grid>
                                            </DataTemplate>
                                        </TreeViewItem.HeaderTemplate>
                                    </TreeViewItem>
                                </TreeViewItem>

                                <!-- Cooling -->
                                <TreeViewItem Header="Cooling Output Ports M7, M8, M9" IsExpanded="True"
                                              FontWeight="SemiBold">
                                    <TreeViewItem Header="">
                                        <TreeViewItem.HeaderTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="200"/>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="60"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="Enable cooling" FontStyle="Italic"/>
                                                    <TextBox Grid.Column="1" Text="3" Margin="2,1" Height="20"/>
                                                    <CheckBox Grid.Column="2" Margin="4,0"/>
                                                    <TextBlock Grid.Column="3" Text="M8" Foreground="#666"/>
                                                </Grid>
                                            </DataTemplate>
                                        </TreeViewItem.HeaderTemplate>
                                    </TreeViewItem>
                                    <TreeViewItem Header="">
                                        <TreeViewItem.HeaderTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="200"/>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="60"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="Mist coolant" FontStyle="Italic"/>
                                                    <TextBox Grid.Column="1" Text="4" Margin="2,1" Height="20"/>
                                                    <CheckBox Grid.Column="2" Margin="4,0"/>
                                                    <TextBlock Grid.Column="3" Text="M7" Foreground="#666"/>
                                                </Grid>
                                            </DataTemplate>
                                        </TreeViewItem.HeaderTemplate>
                                    </TreeViewItem>
                                </TreeViewItem>

                                <!-- Output Control -->
                                <TreeViewItem Header="Output Control M62, M63, M64, M65" IsExpanded="False"
                                              FontWeight="SemiBold">
                                    <TreeViewItem Header="Output port 0 — M62 P0 / M64 P0"/>
                                    <TreeViewItem Header="Output port 1 — M62 P1 / M64 P1"/>
                                    <TreeViewItem Header="Output port 2 — M62 P2 / M64 P2"/>
                                </TreeViewItem>

                                <!-- Enable axles -->
                                <TreeViewItem Header="Enable axles Output Ports" IsExpanded="False"
                                              FontWeight="SemiBold">
                                    <TreeViewItem Header="Enable X axle"/>
                                    <TreeViewItem Header="Enable Y axle"/>
                                    <TreeViewItem Header="Enable Z axle"/>
                                    <TreeViewItem Header="Enable A axle"/>
                                </TreeViewItem>
                            </TreeView>
                        </Border>

                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <Label Content="The period of scanning coordinates:"/>
                            <TextBox Grid.Column="1" x:Name="TbScanPeriod" Text="20" Margin="4,0,0,0"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══════════ TAB: Device controller ═══════════ -->
            <TabItem Header="Device controller" Tag="🖧">
                <DockPanel Margin="10" Background="White">
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Devices:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        <CheckBox Grid.Column="1" Content="Automatic selection of supported device"
                                  x:Name="ChkAutoDevice" IsChecked="True"
                                  VerticalAlignment="Center" Margin="8,0"/>
                        <Button Grid.Column="2" Content="🔄 Refresh" Width="80"
                                Click="BtnRefreshDevices_Click" Padding="4,2"/>
                    </Grid>

                    <Grid DockPanel.Dock="Bottom" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="70"/>
                        </Grid.ColumnDefinitions>
                        <Label Content="The period of scanning coordinates:"/>
                        <TextBox Grid.Column="1" x:Name="TbScanPeriod2" Text="20" Margin="4,0,0,0"/>
                    </Grid>

                    <!-- Lista de dispositivos USB -->
                    <DataGrid x:Name="DeviceGrid" Margin="0,4" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name"          Width="120" Binding="{Binding Name}"/>
                            <DataGridTextColumn Header="Manufacturer"  Width="100" Binding="{Binding Manufacturer}"/>
                            <DataGridTextColumn Header="VID"           Width="50"  Binding="{Binding VID}"/>
                            <DataGridTextColumn Header="PID"           Width="50"  Binding="{Binding PID}"/>
                            <DataGridTextColumn Header="Version"       Width="55"  Binding="{Binding Version}"/>
                            <DataGridTextColumn Header="Serial number" Width="100" Binding="{Binding Serial}"/>
                            <DataGridTextColumn Header="Outp."         Width="45"  Binding="{Binding Outputs}"/>
                            <DataGridTextColumn Header="Input."        Width="45"  Binding="{Binding Inputs}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- ═══════════ TAB: Axes settings ═══════════ -->
            <TabItem Header="Axes settings" Tag="↔">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="White">
                    <StackPanel Margin="10">
                        <!-- Cabeçalho -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="75"/>
                                <ColumnDefinition Width="75"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="" FontWeight="Bold" FontSize="10" Foreground="#555"/>
                            <TextBlock Grid.Column="1" Text="Impulses/mm" FontWeight="Bold" FontSize="10" Foreground="#555" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="Max (mm)" FontWeight="Bold" FontSize="10" Foreground="#555" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="Min (mm)" FontWeight="Bold" FontSize="10" Foreground="#555" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="Backlash mm" FontWeight="Bold" FontSize="10" Foreground="#555" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="5" Text="Accel/min" FontWeight="Bold" FontSize="10" Foreground="#555" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="6" Text="Step↕" FontWeight="Bold" FontSize="10" Foreground="#555" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="7" Text="Dir↕" FontWeight="Bold" FontSize="10" Foreground="#555" HorizontalAlignment="Center"/>
                        </Grid>
                        <Separator Background="#ddd" Margin="0,2,0,4"/>

                        <!-- Linhas de eixo -->
                        <ItemsControl x:Name="AxesPanel">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Height="28" Margin="0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="30"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="75"/>
                                            <ColumnDefinition Width="75"/>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="60"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="16"
                                                   FontWeight="Bold" Foreground="{Binding Color}"
                                                   VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" Text="{Binding Pulses}" Margin="2,2"/>
                                        <TextBox Grid.Column="2" Text="{Binding Max}" Margin="2,2"/>
                                        <TextBox Grid.Column="3" Text="{Binding Min}" Margin="2,2"/>
                                        <TextBox Grid.Column="4" Text="{Binding Backlash}" Margin="2,2"/>
                                        <TextBox Grid.Column="5" Text="{Binding Accel}" Margin="2,2"/>
                                        <CheckBox Grid.Column="6" IsChecked="{Binding StepInv}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <CheckBox Grid.Column="7" IsChecked="{Binding DirInv}"  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══════════ TAB: Input Ports ═══════════ -->
            <TabItem Header="Input Ports" Tag="→">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="White">
                    <StackPanel Margin="10">
                        <DataGrid x:Name="InputPortsGrid" AutoGenerateColumns="False"
                                  IsReadOnly="False" MinHeight="200">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name" Width="160" Binding="{Binding Name}" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Port number" Width="80" Binding="{Binding Port}"/>
                                <DataGridCheckBoxColumn Header="Invert" Width="55" Binding="{Binding Invert}"/>
                                <DataGridTextColumn Header="Description" Width="*" Binding="{Binding Desc}" IsReadOnly="True"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <Separator Margin="0,8"/>
                        <CheckBox Content="Enable hard limits (alarm on trigger)" x:Name="ChkHardLimits" Margin="0,4"/>
                        <CheckBox Content="Input port diagnostics on startup" x:Name="ChkInputDiag" Margin="0,4"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══════════ TAB: Output Ports ═══════════ -->
            <TabItem Header="Output Ports" Tag="←">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="White">
                    <StackPanel Margin="10">
                        <DataGrid x:Name="OutputPortsGrid" AutoGenerateColumns="False"
                                  IsReadOnly="False" MinHeight="200">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name" Width="160" Binding="{Binding Name}" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Port number" Width="80" Binding="{Binding Port}"/>
                                <DataGridCheckBoxColumn Header="Invert" Width="55" Binding="{Binding Invert}"/>
                                <DataGridTextColumn Header="Description" Width="*" Binding="{Binding Desc}" IsReadOnly="True"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══════════ TAB: Spindle ═══════════ -->
            <TabItem Header="Spindle" Tag="⚡">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="White">
                    <StackPanel Margin="10">
                        <GroupBox Header="Spindle specifications">
                            <Grid Margin="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/><ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="28"/><RowDefinition Height="28"/>
                                    <RowDefinition Height="28"/><RowDefinition Height="28"/>
                                    <RowDefinition Height="28"/><RowDefinition Height="28"/>
                                </Grid.RowDefinitions>
                                <Label Grid.Row="0" Content="Max spindle speed (rpm):"/>
                                <TextBox Grid.Row="0" Grid.Column="1" x:Name="TbSpMax" Text="24000" Margin="2"/>
                                <Label Grid.Row="1" Content="Min spindle speed (rpm):"/>
                                <TextBox Grid.Row="1" Grid.Column="1" x:Name="TbSpMin" Text="0" Margin="2"/>
                                <Label Grid.Row="2" Content="PWM frequency (Hz):"/>
                                <TextBox Grid.Row="2" Grid.Column="1" x:Name="TbPwmFreq" Text="1000" Margin="2"/>
                                <Label Grid.Row="3" Content="Spindle coefficient:"/>
                                <TextBox Grid.Row="3" Grid.Column="1" x:Name="TbSpCoeff" Text="1.0" Margin="2"/>
                                <Label Grid.Row="4" Content="Axis for PWM signal:"/>
                                <ComboBox Grid.Row="4" Grid.Column="1" x:Name="CmbPwmAxis" Margin="2">
                                    <ComboBoxItem Content="Z axis" IsSelected="True"/>
                                    <ComboBoxItem Content="A axis"/>
                                    <ComboBoxItem Content="Disabled"/>
                                </ComboBox>
                                <Label Grid.Row="5" Content="Speed signal multiplier:"/>
                                <TextBox Grid.Row="5" Grid.Column="1" x:Name="TbSpeedMult" Text="1.0" Margin="2"/>
                            </Grid>
                        </GroupBox>
                        <GroupBox Header="Spindle control">
                            <StackPanel Margin="4">
                                <CheckBox Content="Turn on/off the spindle (M3/M4/M5)" IsChecked="True" x:Name="ChkSpEnable" Margin="0,3"/>
                                <CheckBox Content="Direction of rotation of the spindle" x:Name="ChkSpDir" Margin="0,3"/>
                                <CheckBox Content="Use acceleration (rpm/10ms)" x:Name="ChkSpAccel" Margin="0,3"/>
                                <CheckBox Content="Invert output signal" x:Name="ChkSpInvOut" Margin="0,3"/>
                                <CheckBox Content="Invert 0-10V output" x:Name="ChkSp010" Margin="0,3"/>
                                <CheckBox Content="DIR signal for on / off" x:Name="ChkSpDirOnOff" Margin="0,3"/>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══════════ TAB: Machine size ═══════════ -->
            <TabItem Header="Machine size" Tag="📐">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="White">
                    <StackPanel Margin="10">
                        <GroupBox Header="Machine size, soft limits, home function.">
                            <Grid Margin="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130"/><ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="90"/><ColumnDefinition Width="90"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="26"/><RowDefinition Height="26"/>
                                    <RowDefinition Height="26"/><RowDefinition Height="26"/>
                                    <RowDefinition Height="26"/><RowDefinition Height="26"/>
                                    <RowDefinition Height="26"/>
                                </Grid.RowDefinitions>

                                <Label Grid.Row="0" Grid.Column="1" Content="Min (mm)" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                <Label Grid.Row="0" Grid.Column="2" Content="Max (mm)" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                <Label Grid.Row="0" Grid.Column="3" Content="Home dir" HorizontalAlignment="Center" FontWeight="SemiBold"/>

                                <Label Grid.Row="1" Content="X axis:" Foreground="#e53935"/>
                                <TextBox Grid.Row="1" Grid.Column="1" x:Name="TbXSoftMin" Text="0" Margin="2"/>
                                <TextBox Grid.Row="1" Grid.Column="2" x:Name="TbXSoftMax" Text="200" Margin="2"/>
                                <ComboBox Grid.Row="1" Grid.Column="3" Margin="2">
                                    <ComboBoxItem Content="Min (-)"/>
                                    <ComboBoxItem Content="Max (+)" IsSelected="True"/>
                                </ComboBox>

                                <Label Grid.Row="2" Content="Y axis:" Foreground="#fdd835"/>
                                <TextBox Grid.Row="2" Grid.Column="1" x:Name="TbYSoftMin" Text="0" Margin="2"/>
                                <TextBox Grid.Row="2" Grid.Column="2" x:Name="TbYSoftMax" Text="200" Margin="2"/>
                                <ComboBox Grid.Row="2" Grid.Column="3" Margin="2">
                                    <ComboBoxItem Content="Min (-)"/>
                                    <ComboBoxItem Content="Max (+)" IsSelected="True"/>
                                </ComboBox>

                                <Label Grid.Row="3" Content="Z axis:" Foreground="#1e88e5"/>
                                <TextBox Grid.Row="3" Grid.Column="1" x:Name="TbZSoftMin" Text="-100" Margin="2"/>
                                <TextBox Grid.Row="3" Grid.Column="2" x:Name="TbZSoftMax" Text="0" Margin="2"/>
                                <ComboBox Grid.Row="3" Grid.Column="3" Margin="2">
                                    <ComboBoxItem Content="Min (-)" IsSelected="True"/>
                                    <ComboBoxItem Content="Max (+)"/>
                                </ComboBox>

                                <Label Grid.Row="4" Content="A axis:" Foreground="#ab47bc"/>
                                <TextBox Grid.Row="4" Grid.Column="1" x:Name="TbASoftMin" Text="0" Margin="2"/>
                                <TextBox Grid.Row="4" Grid.Column="2" x:Name="TbASoftMax" Text="360" Margin="2"/>
                                <ComboBox Grid.Row="4" Grid.Column="3" Margin="2">
                                    <ComboBoxItem Content="Min (-)"/>
                                    <ComboBoxItem Content="Max (+)" IsSelected="True"/>
                                </ComboBox>
                            </Grid>
                        </GroupBox>
                        <GroupBox Header="Home functions">
                            <Grid Margin="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/><ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="26"/><RowDefinition Height="26"/>
                                    <RowDefinition Height="26"/><RowDefinition Height="26"/>
                                    <RowDefinition Height="26"/>
                                </Grid.RowDefinitions>
                                <Label Grid.Row="0" Content="Homing order:"/>
                                <ComboBox Grid.Row="0" Grid.Column="1" Margin="2">
                                    <ComboBoxItem Content="Z → X → Y" IsSelected="True"/>
                                    <ComboBoxItem Content="X → Y → Z"/>
                                    <ComboBoxItem Content="All simultaneous"/>
                                </ComboBox>
                                <Label Grid.Row="1" Content="Seek speed (mm/min):"/>
                                <TextBox Grid.Row="1" Grid.Column="1" x:Name="TbHomeSeek" Text="800" Margin="2"/>

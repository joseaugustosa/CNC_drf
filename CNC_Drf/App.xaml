<Application x:Class="CNC_Drf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:core="clr-namespace:CNC_Drf.Core"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <core:BoolToSpindleLabelConverter  x:Key="BoolToSpindleLabel"/>
        <core:BoolToConnectLabelConverter  x:Key="BoolToConnectLabel"/>
        <core:BoolToBgConverter            x:Key="BoolToBgConverter"/>
        <core:InvertBoolConverter          x:Key="InvertBoolConverter"/>
        <core:EmptyToVisibleConverter      x:Key="EmptyToVisibleConverter"/>
        <core:CommentColorConverter        x:Key="CommentColorConverter"/>
        <core:BoolToVisibleConverter        x:Key="BoolToVisibleConverter"/>
        <core:InvertBoolToVisibleConverter  x:Key="InvertBoolToVisibleConverter"/>
    </Application.Resources>
</Application>

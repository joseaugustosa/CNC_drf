<Window x:Class="CNC_Drf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:CNC_Drf.Views"
        xmlns:dlg="clr-namespace:CNC_Drf.Dialogs"
        Title="CNC_Drf" Height="700" Width="1280"
        MinHeight="580" MinWidth="960"
        Background="#2b2b2b" Foreground="#e0e0e0"
        Closing="Window_Closing">

    <DockPanel>
        <!-- ── Toolbar principal ────────────────────────────────────────── -->
        <ToolBar DockPanel.Dock="Top" Background="#1a1a1a" Height="34" Padding="2,0">
            <!-- G-code tools -->
            <Button Content="📂" ToolTip="Open File" Click="BtnOpenFile_Click"
                    Background="Transparent" Foreground="White" BorderBrush="Transparent" FontSize="16"/>
            <Button Content="💾" ToolTip="Save G-code" Click="BtnSaveFile_Click"
                    Background="Transparent" Foreground="White" BorderBrush="Transparent" FontSize="16"/>
            <Button Content="✏" ToolTip="Edit G-Code" Click="BtnEditFile_Click"
                    Background="Transparent" Foreground="White" BorderBrush="Transparent" FontSize="16"/>
            <Separator/>

            <!-- Run controls -->
            <Button ToolTip="Start" Click="BtnStart_Click" Padding="6,2"
                    Background="#2e7d32" Foreground="White" BorderBrush="#388e3c">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="▶" FontSize="13" Margin="0,0,4,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Start" FontWeight="Bold" FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button ToolTip="Feed Hold" Click="BtnHold_Click" Padding="4,2"
                    Background="#37474f" Foreground="White" BorderBrush="#546e7a">
                <TextBlock Text="⏸ Hold" FontSize="11" FontWeight="Bold"/>
            </Button>
            <Button ToolTip="Smooth Stop" Click="BtnSmoothStop_Click" Padding="4,2"
                    Background="#37474f" Foreground="#f9e2af" BorderBrush="#546e7a">
                <TextBlock Text="🟡 Smooth" FontSize="11" FontWeight="Bold"/>
            </Button>
            <Button ToolTip="Stop / Soft Reset" Click="BtnStop_Click" Padding="4,2"
                    Background="#c62828" Foreground="White" BorderBrush="#b71c1c">
                <TextBlock Text="■ Stop" FontSize="11" FontWeight="Bold"/>
            </Button>
            <Separator/>

            <!-- Speed -->
            <Button Content="▼ Speed" ToolTip="Decrease speed" Click="BtnSpeedDec_Click"
                    Padding="4,2" Background="#333" Foreground="#ef9a9a" BorderBrush="#555" FontSize="10" FontWeight="Bold"/>
            <TextBlock Text="{Binding FeedOverride, StringFormat='{}{0:F0}%'}" VerticalAlignment="Center"
                       Foreground="#f9e2af" FontSize="11" FontWeight="Bold" Margin="4,0"/>
            <Button Content="▲ Speed" ToolTip="Increase speed" Click="BtnSpeedInc_Click"
                    Padding="4,2" Background="#333" Foreground="#a5d6a7" BorderBrush="#555" FontSize="10" FontWeight="Bold"/>
            <Separator/>

            <!-- View controls -->
            <ToggleButton Content="📐 Grid" ToolTip="Show/Hide grid" IsChecked="{Binding ShowGrid}"
                          Command="{Binding ToggleGridCommand}"
                          Padding="4,2" Background="#333" Foreground="#ccc" BorderBrush="#555" FontSize="10"/>
            <Button Content="⊡ Fit" ToolTip="Fit to view" Click="BtnFitView_Click"
                    Padding="4,2" Background="#333" Foreground="#ccc" BorderBrush="#555" FontSize="10"/>
            <Separator/>

            <!-- Settings -->
            <Button Content="⚙ Settings" ToolTip="Open Settings" Click="BtnSettings_Click"
                    Padding="6,2" Background="#444" Foreground="White" BorderBrush="#666" FontSize="10" FontWeight="Bold"/>
            <Button Content="ℹ About" ToolTip="About DrufelCNC" Click="BtnAbout_Click"
                    Padding="4,2" Background="#333" Foreground="#90caf9" BorderBrush="#555" FontSize="10"/>
            <Separator/>

            <!-- Status -->
            <TextBlock Text="{Binding StatusText}" Foreground="#77bb77" VerticalAlignment="Center"
                       FontSize="10" Margin="4,0" MaxWidth="320" TextTrimming="CharacterEllipsis"/>
        </ToolBar>

        <!-- ── StatusBar inferior ───────────────────────────────────────── -->
        <StatusBar DockPanel.Dock="Bottom" Background="#1a1a1a" Height="22">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding StatusText}" Foreground="#77bb77" FontSize="10" MaxWidth="400" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🎛 " FontSize="10" Foreground="#90caf9"/>
                    <TextBlock Text="{Binding ControllerName}" Foreground="#90caf9" FontSize="10" FontWeight="Bold"/>
                </StackPanel>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding TaskTime, StringFormat='Task: {0}'}" Foreground="#aaa" FontSize="10"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding CurrentLine, StringFormat='Line: {0}'}" Foreground="#aaa" FontSize="10"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding TotalLines, StringFormat='/ {0}'}" Foreground="#aaa" FontSize="10"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding Progress, StringFormat='{}{0:F1}%'}" Foreground="#aaa" FontSize="10"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding Connected, Converter={StaticResource BoolToConnectLabel}}" Foreground="{Binding Connected, Converter={StaticResource BoolToBgConverter}}" FontSize="10" FontWeight="Bold"/>
            </StatusBarItem>
        </StatusBar>

        <!-- ── Layout principal ─────────────────────────────────────────── -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230" MinWidth="180"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*" MinWidth="300"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="420" MinWidth="300"/>
            </Grid.ColumnDefinitions>

            <views:ControlPanel x:Name="CtrlPanel" Grid.Column="0" DataContext="{Binding}"/>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#444"/>

            <views:VisualizerPanel x:Name="VisPanel" Grid.Column="2" DataContext="{Binding}"/>

            <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch" Background="#444"/>

            <views:GCodePanel x:Name="GcodePanel" Grid.Column="4" DataContext="{Binding}"/>
        </Grid>
    </DockPanel>
</Window>

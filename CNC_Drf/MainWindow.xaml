<Window x:Class="CNC_Drf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:CNC_Drf.Views"
        xmlns:dlg="clr-namespace:CNC_Drf.Dialogs"
        Title="DrufelCNC" Height="700" Width="1280"
        MinHeight="580" MinWidth="960"
        Background="#2b2b2b" Foreground="#e0e0e0"
        Closing="Window_Closing">

    <DockPanel>
        <!-- Barra de menu topo -->
        <ToolBar DockPanel.Dock="Top" Background="#1a1a1a" Height="32">
            <Button Content="⚙ Settings" Click="BtnSettings_Click"
                    Background="#333" Foreground="White" BorderBrush="#555"
                    Padding="8,3" FontSize="11"/>
            <Separator Background="#444"/>
            <TextBlock VerticalAlignment="Center" Foreground="#777" FontSize="10" Margin="6,0"
                       Text="{Binding StatusText}"/>
        </ToolBar>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Esquerda: G-code + controlo execução -->
            <ColumnDefinition Width="200" MinWidth="160"/>
            <ColumnDefinition Width="3"/>
            <!-- Centro: DRO + Jog -->
            <ColumnDefinition Width="240" MinWidth="220"/>
            <ColumnDefinition Width="3"/>
            <!-- Direita: Viewport -->
            <ColumnDefinition Width="*" MinWidth="300"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- COLUNA ESQUERDA — G-code                                       -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <views:GCodePanel x:Name="GcodePanel" Grid.Column="0" DataContext="{Binding}"/>

        <GridSplitter Grid.Column="1" Width="3" HorizontalAlignment="Stretch" Background="#555"/>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- COLUNA CENTRAL — DRO + Jog                                     -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <views:ControlPanel x:Name="CtrlPanel" Grid.Column="2" DataContext="{Binding}"/>

        <GridSplitter Grid.Column="3" Width="3" HorizontalAlignment="Stretch" Background="#555"/>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- COLUNA DIREITA — Viewport 2D/3D                                -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <views:VisualizerPanel x:Name="VisPanel" Grid.Column="4" DataContext="{Binding}"/>
    </Grid>
    </DockPanel>
</Window>

<Window x:Class="CNC_Drf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:CNC_Drf.Views"
        xmlns:core="clr-namespace:CNC_Drf.Core"
        Title="CNC Drf — Controller" Height="780" Width="1300"
        MinHeight="600" MinWidth="900"
        Background="{StaticResource BgBase}">

    <Window.Resources>
        <core:BoolToSpindleLabelConverter  x:Key="BoolToSpindleLabel"/>
        <core:BoolToConnectLabelConverter  x:Key="BoolToConnectLabel"/>
    </Window.Resources>

    <DockPanel>
        <!-- ── Toolbar principal ────────────────────────────────────────── -->
        <ToolBar DockPanel.Dock="Top" Style="{StaticResource DarkToolBar}">
            <!-- Porta -->
            <Label Content="Porta:" Foreground="{StaticResource FgSubtext}" VerticalAlignment="Center"/>
            <ComboBox x:Name="CmbPort" Width="90" Margin="2"
                      ItemsSource="{Binding AvailablePorts}"
                      SelectedItem="{Binding PortName}"/>

            <Label Content="Baud:" Foreground="{StaticResource FgSubtext}" VerticalAlignment="Center"/>
            <ComboBox Width="90" Margin="2" SelectedValue="{Binding BaudRate}" SelectedValuePath="Tag">
                <ComboBoxItem Content="9600"   Tag="9600"/>
                <ComboBoxItem Content="57600"  Tag="57600"/>
                <ComboBoxItem Content="115200" Tag="115200" IsSelected="True"/>
                <ComboBoxItem Content="250000" Tag="250000"/>
            </ComboBox>

            <Button Content="↺" Width="28" Margin="2" ToolTip="Atualizar portas" Click="BtnRefreshPorts_Click"/>

            <ToggleButton x:Name="BtnConnect"
                          Style="{StaticResource ConnectToggle}"
                          IsChecked="{Binding Connected, Mode=OneWay}"
                          Command="{Binding ToggleConnectCommand}"
                          ToolTip="Ligar / Desligar"
                          Content="{Binding Connected, Converter={StaticResource BoolToConnectLabel}}"/>

            <Separator/>

            <!-- Controlo de execução -->
            <Button Style="{StaticResource SmallButton}" Background="#40a02b" Foreground="White"
                    Content="▶ Start" Command="{Binding CycleResumeCommand}" Margin="2"/>
            <Button Style="{StaticResource SmallButton}" Background="#df8e1d" Foreground="White"
                    Content="⏸ Hold"  Command="{Binding FeedHoldCommand}"    Margin="2"/>
            <Button Style="{StaticResource SmallButton}" Background="#d20f39" Foreground="White"
                    Content="■ Reset" Command="{Binding SoftResetCommand}"   Margin="2"/>
            <Button Style="{StaticResource SmallButton}" Content="⌂ Home"
                    Command="{Binding HomeCommand}" Margin="2"/>

            <Separator/>

            <!-- Linha de estado rápida -->
            <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource Accent}"
                       VerticalAlignment="Center" FontWeight="SemiBold" Margin="8,0"/>
        </ToolBar>

        <!-- ── Barra de estado ───────────────────────────────────────────── -->
        <StatusBar DockPanel.Dock="Bottom" Style="{StaticResource DarkStatusBar}">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding CurrentLine, StringFormat='Linha: {0}'}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding TotalLines, StringFormat='Total: {0}'}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding Progress, StringFormat='Progresso: {0:F1}%'}"/>
            </StatusBarItem>
        </StatusBar>

        <!-- ── Layout principal ─────────────────────────────────────────── -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230" MinWidth="180"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*" MinWidth="300"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="380" MinWidth="260"/>
            </Grid.ColumnDefinitions>

            <!-- Coluna esquerda: DRO + Jog -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <views:DroPanel DataContext="{Binding}"/>
                    <views:JogPanel DataContext="{Binding}" Margin="0,4,0,0"/>

                    <!-- MDI / Comando manual -->
                    <GroupBox Header="Comando MDI" Style="{StaticResource DarkGroupBox}" Margin="2,4">
                        <StackPanel Orientation="Horizontal" Margin="2">
                            <TextBox x:Name="TbMdi" Style="{StaticResource MonoTextBox}"
                                     Width="130" Margin="0,0,4,0"
                                     KeyDown="TbMdi_KeyDown"/>
                            <Button Content="Enviar" Style="{StaticResource SmallButton}"
                                    Click="BtnMdiSend_Click"/>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="{StaticResource BgSurface0}"/>

            <!-- Coluna central: Visualizador 3D -->
            <views:VisualizerPanel x:Name="VisPanel" Grid.Column="2" DataContext="{Binding}"/>

            <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch"
                          Background="{StaticResource BgSurface0}"/>

            <!-- Coluna direita: G-code + Log -->
            <views:GCodePanel Grid.Column="4" DataContext="{Binding}"/>
        </Grid>
    </DockPanel>
</Window>

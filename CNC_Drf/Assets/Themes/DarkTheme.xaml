<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Cores (Catppuccin Mocha) ─────────────────────────────────────── -->
    <SolidColorBrush x:Key="BgBase"     Color="#1e1e2e"/>
    <SolidColorBrush x:Key="BgMantle"   Color="#181825"/>
    <SolidColorBrush x:Key="BgSurface0" Color="#313244"/>
    <SolidColorBrush x:Key="BgSurface1" Color="#45475a"/>
    <SolidColorBrush x:Key="FgText"     Color="#cdd6f4"/>
    <SolidColorBrush x:Key="FgSubtext"  Color="#6c7086"/>
    <SolidColorBrush x:Key="Accent"     Color="#89b4fa"/>
    <SolidColorBrush x:Key="Green"      Color="#a6e3a1"/>
    <SolidColorBrush x:Key="Red"        Color="#f38ba8"/>
    <SolidColorBrush x:Key="Orange"     Color="#fab387"/>
    <SolidColorBrush x:Key="Yellow"     Color="#f9e2af"/>
    <SolidColorBrush x:Key="Terminal"   Color="#11111b"/>

    <!-- Override SystemColors para dark mode global -->
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}"                    Color="#1e1e2e"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}"                   Color="#1e1e2e"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}"                Color="#cdd6f4"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}"               Color="#cdd6f4"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"                 Color="#45475a"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}"             Color="#cdd6f4"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#313244"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#cdd6f4"/>

    <!-- ── Window ───────────────────────────────────────────────────────── -->
    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource BgBase}"/>
        <Setter Property="Foreground" Value="{StaticResource FgText}"/>
    </Style>

    <!-- ── GroupBox ─────────────────────────────────────────────────────── -->
    <Style x:Key="DarkGroupBox" TargetType="GroupBox">
        <Setter Property="Foreground"      Value="{StaticResource FgText}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource BgSurface0}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Margin"          Value="2"/>
        <Setter Property="Padding"         Value="4"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GroupBox">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="{StaticResource BgSurface0}"
                                CornerRadius="4,4,0,0" Padding="8,3">
                            <ContentPresenter ContentSource="Header"
                                              TextElement.Foreground="{StaticResource Accent}"
                                              TextElement.FontWeight="SemiBold"
                                              TextElement.FontSize="12"/>
                        </Border>
                        <Border Grid.Row="1" BorderBrush="{StaticResource BgSurface0}"
                                BorderThickness="1" CornerRadius="0,0,4,4"
                                Background="{StaticResource BgMantle}" Padding="4">
                            <ContentPresenter/>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Labels ───────────────────────────────────────────────────────── -->
    <Style x:Key="SmallLabel" TargetType="Label">
        <Setter Property="Foreground"        Value="{StaticResource FgSubtext}"/>
        <Setter Property="FontSize"          Value="11"/>
        <Setter Property="Padding"           Value="2,0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <Style x:Key="DroDisplay" TargetType="TextBlock">
        <Setter Property="FontFamily"    Value="Consolas, Courier New, monospace"/>
        <Setter Property="FontSize"      Value="24"/>
        <Setter Property="FontWeight"    Value="Bold"/>
        <Setter Property="Foreground"    Value="{StaticResource Green}"/>
        <Setter Property="Background"    Value="{StaticResource Terminal}"/>
        <Setter Property="Padding"       Value="8,4"/>
        <Setter Property="TextAlignment" Value="Right"/>
    </Style>

    <!-- ── Buttons ──────────────────────────────────────────────────────── -->
    <Style x:Key="BaseButton" TargetType="Button">
        <Setter Property="Foreground"      Value="{StaticResource FgText}"/>
        <Setter Property="Background"      Value="{StaticResource BgSurface0}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource BgSurface1}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"         Value="8,4"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource BgSurface1}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#89b4fa22"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style TargetType="Button" BasedOn="{StaticResource BaseButton}"/>
    <Style x:Key="SmallButton"   BasedOn="{StaticResource BaseButton}" TargetType="Button">
        <Setter Property="Padding" Value="6,3"/>
        <Setter Property="FontSize" Value="11"/>
    </Style>
    <Style x:Key="PrimaryButton" BasedOn="{StaticResource BaseButton}" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource Accent}"/>
        <Setter Property="Foreground" Value="#1e1e2e"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>
    <Style x:Key="StartButton" BasedOn="{StaticResource BaseButton}" TargetType="Button">
        <Setter Property="Background" Value="#40a02b"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>
    <Style x:Key="HoldButton" BasedOn="{StaticResource BaseButton}" TargetType="Button">
        <Setter Property="Background" Value="#df8e1d"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>
    <Style x:Key="AbortButton" BasedOn="{StaticResource BaseButton}" TargetType="Button">
        <Setter Property="Background" Value="#d20f39"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>
    <Style x:Key="JogButton" BasedOn="{StaticResource BaseButton}" TargetType="Button">
        <Setter Property="Width"      Value="52"/>
        <Setter Property="Height"     Value="42"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="FontSize"   Value="14"/>
    </Style>

    <!-- ── ToggleButton ─────────────────────────────────────────────────── -->
    <Style x:Key="DarkToggleButton" TargetType="ToggleButton">
        <Setter Property="Foreground"      Value="{StaticResource FgText}"/>
        <Setter Property="Background"      Value="{StaticResource BgSurface0}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource BgSurface1}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"         Value="6,3"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter Property="Background"  Value="#89b4fa33"/>
                            <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource BgSurface1}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="ConnectToggle" BasedOn="{StaticResource DarkToggleButton}" TargetType="ToggleButton">
        <Setter Property="Width" Value="80"/>
        <Style.Triggers>
            <Trigger Property="IsChecked" Value="True">
                <Setter Property="Background"  Value="#40a02b"/>
                <Setter Property="BorderBrush" Value="#40a02b"/>
                <Setter Property="Foreground"  Value="White"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ── TextBox ──────────────────────────────────────────────────────── -->
    <Style x:Key="DarkTextBox" TargetType="TextBox">
        <Setter Property="Background"  Value="{StaticResource BgBase}"/>
        <Setter Property="Foreground"  Value="{StaticResource FgText}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BgSurface1}"/>
        <Setter Property="CaretBrush"  Value="{StaticResource FgText}"/>
        <Setter Property="Padding"     Value="4,3"/>
        <Setter Property="FontSize"    Value="12"/>
    </Style>
    <Style TargetType="TextBox" BasedOn="{StaticResource DarkTextBox}"/>
    <Style x:Key="MonoTextBox" BasedOn="{StaticResource DarkTextBox}" TargetType="TextBox">
        <Setter Property="FontFamily" Value="Consolas, Courier New, monospace"/>
    </Style>

    <!-- ── ComboBox (template completo para forçar dark em todos os estados) ── -->
    <Style x:Key="DarkCombo" TargetType="ComboBox">
        <Setter Property="Background"      Value="{StaticResource BgBase}"/>
        <Setter Property="Foreground"      Value="{StaticResource FgText}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource BgSurface1}"/>
        <Setter Property="Padding"         Value="4,3"/>
        <Setter Property="MinHeight"       Value="30"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <Border x:Name="OuterBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="4"/>
                        <Grid Margin="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="28"/>
                            </Grid.ColumnDefinitions>
                            <ContentPresenter x:Name="ContentSite"
                                              Margin="8,3,6,3"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              IsHitTestVisible="False"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                            <ToggleButton Grid.Column="1" Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Background="Transparent" BorderBrush="Transparent">
                                <Path HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Fill="{TemplateBinding Foreground}" Data="M 0 0 L 8 0 L 4 5 Z"/>
                            </ToggleButton>
                        </Grid>
                        <Popup x:Name="Popup" Placement="Bottom"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                            <Border Margin="0,2,0,0"
                                    MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                    Background="{StaticResource BgBase}"
                                    BorderBrush="{StaticResource BgSurface1}"
                                    BorderThickness="1" CornerRadius="4">
                                <ScrollViewer MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                              CanContentScroll="True" SnapsToDevicePixels="True">
                                    <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="OuterBorder" Property="Background" Value="{StaticResource BgSurface0}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="OuterBorder" Property="BorderBrush" Value="{StaticResource Accent}"/>
                        </Trigger>
                        <Trigger Property="IsDropDownOpen" Value="True">
                            <Setter TargetName="OuterBorder" Property="Background" Value="{StaticResource BgSurface0}"/>
                            <Setter TargetName="OuterBorder" Property="BorderBrush" Value="{StaticResource Accent}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Background"                Value="{StaticResource BgBase}"/>
                    <Setter Property="Foreground"                Value="{StaticResource FgText}"/>
                    <Setter Property="Padding"                   Value="8,4"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ComboBoxItem">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}">
                                    <ContentPresenter Margin="{TemplateBinding Padding}"
                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      TextElement.Foreground="{TemplateBinding Foreground}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgSurface1}"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#89b4fa33"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Setter.Value>
        </Setter>
    </Style>
    <Style TargetType="ComboBox" BasedOn="{StaticResource DarkCombo}"/>

    <!-- ── ListBox ──────────────────────────────────────────────────────── -->
    <Style x:Key="DarkListBox" TargetType="ListBox">
        <Setter Property="Background"  Value="{StaticResource Terminal}"/>
        <Setter Property="Foreground"  Value="{StaticResource FgText}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BgSurface0}"/>
        <Setter Property="FontFamily"  Value="Consolas, Courier New, monospace"/>
        <Setter Property="FontSize"    Value="12"/>
    </Style>

    <!-- ── Separator ────────────────────────────────────────────────────── -->
    <Style x:Key="DarkSeparator" TargetType="Separator">
        <Setter Property="Background" Value="{StaticResource BgSurface0}"/>
    </Style>

    <!-- ── ToolBar ──────────────────────────────────────────────────────── -->
    <Style x:Key="DarkToolBar" TargetType="ToolBar">
        <Setter Property="Background"      Value="{StaticResource BgMantle}"/>
        <Setter Property="Foreground"      Value="{StaticResource FgText}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="BorderBrush"     Value="{StaticResource BgSurface0}"/>
    </Style>

    <!-- ── StatusBar ────────────────────────────────────────────────────── -->
    <Style x:Key="DarkStatusBar" TargetType="StatusBar">
        <Setter Property="Background" Value="{StaticResource BgMantle}"/>
        <Setter Property="Foreground" Value="{StaticResource FgSubtext}"/>
        <Setter Property="Height"     Value="26"/>
    </Style>

    <!-- ── TabControl / TabItem ─────────────────────────────────────────── -->
    <Style x:Key="DarkTabControl" TargetType="TabControl">
        <Setter Property="Background"  Value="{StaticResource BgMantle}"/>
        <Setter Property="Foreground"  Value="{StaticResource FgText}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BgSurface0}"/>
    </Style>
    <Style TargetType="TabItem">
        <Setter Property="Background"  Value="{StaticResource BgSurface0}"/>
        <Setter Property="Foreground"  Value="{StaticResource FgSubtext}"/>
        <Setter Property="Padding"     Value="10,4"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            BorderBrush="{StaticResource BgSurface0}"
                            BorderThickness="1,1,1,0" CornerRadius="4,4,0,0" Margin="2,2,2,0">
                        <ContentPresenter ContentSource="Header"
                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd"  Property="Background"  Value="{StaticResource BgMantle}"/>
                            <Setter Property="Foreground" Value="{StaticResource Accent}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgSurface1}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── ProgressBar ──────────────────────────────────────────────────── -->
    <Style x:Key="DarkProgressBar" TargetType="ProgressBar">
        <Setter Property="Background"  Value="{StaticResource BgSurface0}"/>
        <Setter Property="Foreground"  Value="{StaticResource Accent}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BgSurface1}"/>
        <Setter Property="Height"      Value="14"/>
    </Style>

    <!-- ── ScrollBar ────────────────────────────────────────────────────── -->
    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="{StaticResource BgSurface0}"/>
    </Style>

    <!-- ── RadioButton ──────────────────────────────────────────────────── -->
    <Style TargetType="RadioButton">
        <Setter Property="Foreground" Value="{StaticResource FgText}"/>
        <Setter Property="Margin"     Value="2,2"/>
    </Style>

    <!-- ── CheckBox ─────────────────────────────────────────────────────── -->
    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource FgText}"/>
        <Setter Property="Margin"     Value="2,2"/>
    </Style>

    <!-- ── TextBlock ────────────────────────────────────────────────────── -->
    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource FgText}"/>
    </Style>

    <!-- ── Label ────────────────────────────────────────────────────────── -->
    <Style TargetType="Label">
        <Setter Property="Foreground" Value="{StaticResource FgText}"/>
    </Style>

</ResourceDictionary>

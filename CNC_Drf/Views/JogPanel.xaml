<UserControl x:Class="CNC_Drf.Views.JogPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <GroupBox Header="Controlo Manual (Jog)" Style="{StaticResource DarkGroupBox}" Margin="0,0,0,4">
            <StackPanel>
                <!-- XY Jog -->
                <Grid Margin="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/><RowDefinition/><RowDefinition/>
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0" Grid.Column="1" Content="Y+" Style="{StaticResource JogButton}"
                            Command="{Binding JogAxisCommand}" CommandParameter="Y:+" Margin="2"/>
                    <Button Grid.Row="1" Grid.Column="0" Content="X-" Style="{StaticResource JogButton}"
                            Command="{Binding JogAxisCommand}" CommandParameter="X:-" Margin="2"/>
                    <Button Grid.Row="1" Grid.Column="1" Content="⌂" Style="{StaticResource JogButton}"
                            Command="{Binding ZeroAllCommand}" Margin="2" ToolTip="G92 X0 Y0 Z0"/>
                    <Button Grid.Row="1" Grid.Column="2" Content="X+" Style="{StaticResource JogButton}"
                            Command="{Binding JogAxisCommand}" CommandParameter="X:+" Margin="2"/>
                    <Button Grid.Row="2" Grid.Column="1" Content="Y-" Style="{StaticResource JogButton}"
                            Command="{Binding JogAxisCommand}" CommandParameter="Y:-" Margin="2"/>
                </Grid>

                <!-- Z Jog -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="4,0">
                    <Button Content="Z+" Style="{StaticResource JogButton}"
                            Command="{Binding JogAxisCommand}" CommandParameter="Z:+" Margin="2"/>
                    <Button Content="Z-" Style="{StaticResource JogButton}"
                            Command="{Binding JogAxisCommand}" CommandParameter="Z:-" Margin="2"/>
                    <Button Content="A+" Style="{StaticResource JogButton}"
                            Command="{Binding JogAxisCommand}" CommandParameter="A:+" Margin="2"/>
                    <Button Content="A-" Style="{StaticResource JogButton}"
                            Command="{Binding JogAxisCommand}" CommandParameter="A:-" Margin="2"/>
                </StackPanel>

                <Separator Style="{StaticResource DarkSeparator}" Margin="4,6"/>

                <!-- Step / Feed -->
                <Grid Margin="4,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/><RowDefinition/>
                    </Grid.RowDefinitions>
                    <Label Grid.Row="0" Content="Passo (mm):" Style="{StaticResource SmallLabel}"/>
                    <ComboBox Grid.Row="0" Grid.Column="1" Margin="4,2"
                              SelectedValue="{Binding JogStep}"
                              SelectedValuePath="Tag">
                        <ComboBoxItem Content="0.001" Tag="0.001"/>
                        <ComboBoxItem Content="0.01"  Tag="0.01"/>
                        <ComboBoxItem Content="0.1"   Tag="0.1"/>
                        <ComboBoxItem Content="1.0"   Tag="1.0" IsSelected="True"/>
                        <ComboBoxItem Content="10.0"  Tag="10.0"/>
                        <ComboBoxItem Content="100.0" Tag="100.0"/>
                    </ComboBox>
                    <Label Grid.Row="1" Content="Feed (mm/min):" Style="{StaticResource SmallLabel}"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Margin="4,2"
                             Text="{Binding JogFeed, StringFormat={}{0:F0}}"/>
                </Grid>
            </StackPanel>
        </GroupBox>

        <GroupBox Header="Spindle / Refrigeração" Style="{StaticResource DarkGroupBox}">
            <Grid Margin="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/><RowDefinition/>
                </Grid.RowDefinitions>

                <Label Grid.Row="0" Content="RPM:" Style="{StaticResource SmallLabel}"/>
                <TextBox Grid.Row="0" Grid.Column="1" Margin="4,2"
                         Text="{Binding SpindleRpm, StringFormat={}{0:F0}}"/>
                <Button Grid.Row="0" Grid.Column="2" Margin="4,2" Width="70"
                        Command="{Binding SpindleToggleCommand}"
                        Content="{Binding SpindleOn, Converter={StaticResource BoolToSpindleLabel}}"
                        Style="{StaticResource StartButton}"/>

                <Label Grid.Row="1" Content="Refrigeração:" Style="{StaticResource SmallLabel}"/>
                <StackPanel Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="4,2">
                    <Button Content="M8 Ligar"    Style="{StaticResource SmallButton}" Margin="2"
                            Command="{Binding CoolantOnCommand}"/>
                    <Button Content="M9 Desligar" Style="{StaticResource SmallButton}" Margin="2"
                            Command="{Binding CoolantOffCommand}"/>
                </StackPanel>
            </Grid>
        </GroupBox>
    </StackPanel>
</UserControl>

<Window x:Class="CNC_Drf.Views.GCodeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="▶  G-Code em Execução"
        Width="500" Height="680"
        MinWidth="360" MinHeight="400"
        Background="#111"
        Foreground="#e0e0e0"
        ShowInTaskbar="True"
        Closing="Window_Closing">

    <Grid>
        <Grid.RowDefinitions>
            <!-- Cabeçalho: ficheiro + pin -->
            <RowDefinition Height="36"/>
            <!-- Painel de execução (linha actual) -->
            <RowDefinition Height="Auto"/>
            <!-- Barra de progresso -->
            <RowDefinition Height="6"/>
            <!-- Controlos Start/Stop -->
            <RowDefinition Height="46"/>
            <!-- Lista G-code -->
            <RowDefinition Height="*"/>
            <!-- Rodapé -->
            <RowDefinition Height="24"/>
        </Grid.RowDefinitions>

        <!-- ════════ LINHA 0: Cabeçalho ════════ -->
        <Border Grid.Row="0" Background="#1a1a1a"
                BorderBrush="#2a2a2a" BorderThickness="0,0,0,1">
            <Grid Margin="8,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="📄 " FontSize="13" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TbFileName" Text="Sem ficheiro"
                               FontSize="12" FontWeight="Bold"
                               Foreground="#90caf9" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TbLineCount" Text=""
                               FontSize="10" Foreground="#555"
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>
                <ToggleButton x:Name="BtnOnTop"
                              HorizontalAlignment="Right" VerticalAlignment="Center"
                              Content="📌 Sempre em cima"
                              Checked="BtnOnTop_Checked" Unchecked="BtnOnTop_Unchecked"
                              Padding="5,2" FontSize="9"
                              Background="#252525" Foreground="#888" BorderBrush="#444"/>
            </Grid>
        </Border>

        <!-- ════════ LINHA 1: Painel de execução ════════ -->
        <Border Grid.Row="1" x:Name="RunningPanel"
                Background="#071a07" BorderBrush="#2e7d32"
                BorderThickness="0,0,0,2" Padding="10,8"
                Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="22"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Indicador + linha + % -->
                <Grid Grid.Row="0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="▶  A EXECUTAR  —  Linha "
                                   FontSize="11" FontWeight="Bold" Foreground="#66bb6a"/>
                        <TextBlock x:Name="TbCurrentLine" Text="0"
                                   FontSize="13" FontWeight="Bold" Foreground="#a5d6a7"/>
                        <TextBlock Text=" / " FontSize="11" Foreground="#444"/>
                        <TextBlock x:Name="TbTotalLines" Text="0"
                                   FontSize="11" Foreground="#666"/>
                    </StackPanel>
                    <TextBlock x:Name="TbPercent" Text="0%"
                               HorizontalAlignment="Right" VerticalAlignment="Center"
                               FontSize="13" FontWeight="Bold" Foreground="#66bb6a"/>
                </Grid>

                <!-- Código actual -->
                <Border Grid.Row="2" Background="#0a2a0a"
                        BorderBrush="#1b5e20" BorderThickness="1"
                        CornerRadius="3" Padding="10,6">
                    <TextBlock x:Name="TbCurrentCode" Text=""
                               FontFamily="Consolas" FontSize="15"
                               FontWeight="Bold" Foreground="#ffcc80"
                               TextTrimming="CharacterEllipsis"/>
                </Border>
            </Grid>
        </Border>

        <!-- ════════ LINHA 2: Barra de progresso ════════ -->
        <ProgressBar Grid.Row="2" x:Name="PbProgress"
                     Value="0" Maximum="100"
                     Background="#1a1a1a" Foreground="#2e7d32"
                     BorderThickness="0"/>

        <!-- ════════ LINHA 3: Controlos ════════ -->
        <Border Grid.Row="3" Background="#161616"
                BorderBrush="#222" BorderThickness="0,0,0,1" Padding="6,5">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                <Button x:Name="BtnStart" Width="82" Height="34" Margin="0,0,4,0"
                        Click="BtnStart_Click"
                        Background="#1b5e20" BorderBrush="#388e3c">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="▶ " FontSize="14" Foreground="#66bb6a" VerticalAlignment="Center"/>
                        <TextBlock Text="START" FontSize="11" FontWeight="Bold"
                                   Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BtnPause" Width="76" Height="34" Margin="0,0,4,0"
                        Click="BtnPause_Click"
                        Background="#1c2d36" BorderBrush="#546e7a">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="⏸ " FontSize="13" Foreground="#90caf9" VerticalAlignment="Center"/>
                        <TextBlock Text="PAUSE" FontSize="11" FontWeight="Bold"
                                   Foreground="#ccc" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BtnResume" Width="86" Height="34" Margin="0,0,4,0"
                        Click="BtnResume_Click"
                        Background="#1a3a1a" BorderBrush="#2e7d32">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="▶▶ " FontSize="11" Foreground="#66bb6a" VerticalAlignment="Center"/>
                        <TextBlock Text="RESUME" FontSize="11" FontWeight="Bold"
                                   Foreground="#a5d6a7" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BtnStop" Width="76" Height="34" Margin="0,0,10,0"
                        Click="BtnStop_Click"
                        Background="#7f0000" BorderBrush="#c62828">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="■ " FontSize="14" Foreground="#ef9a9a" VerticalAlignment="Center"/>
                        <TextBlock Text="STOP" FontSize="11" FontWeight="Bold"
                                   Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <TextBlock x:Name="TbControlStatus"
                           Text="Pronto" Foreground="#66bb6a"
                           FontSize="10" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>
        </Border>

        <!-- ════════ LINHA 4: Lista G-code ════════ -->
        <Grid Grid.Row="4">

            <ListBox x:Name="GcodeList"
                     Background="#111" Foreground="#c8c8c8"
                     BorderThickness="0"
                     FontFamily="Consolas" FontSize="12"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling">

                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding"            Value="0"/>
                        <Setter Property="Margin"             Value="0"/>
                        <Setter Property="Background"         Value="Transparent"/>
                        <Setter Property="BorderThickness"    Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#0d2a0d"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid MinHeight="20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="5"/>
                                <ColumnDefinition Width="48"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Barra lateral verde na linha activa -->
                            <Border Grid.Column="0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected,
                                                         RelativeSource={RelativeSource
                                                         AncestorType=ListBoxItem}}"
                                                         Value="True">
                                                <Setter Property="Background" Value="#4caf50"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>

                            <!-- Número da linha -->
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Number}"
                                       FontSize="10" VerticalAlignment="Center"
                                       HorizontalAlignment="Right" Margin="0,0,8,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#3a3a3a"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected,
                                                         RelativeSource={RelativeSource
                                                         AncestorType=ListBoxItem}}"
                                                         Value="True">
                                                <Setter Property="Foreground" Value="#a5d6a7"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- Código G -->
                            <TextBlock Grid.Column="2"
                                       Text="{Binding Raw}"
                                       FontFamily="Consolas" FontSize="12"
                                       Padding="0,2"
                                       Foreground="{Binding IsComment,
                                                    Converter={StaticResource CommentColorConverter}}"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Overlay quando não há ficheiro -->
            <StackPanel x:Name="EmptyOverlay"
                        VerticalAlignment="Center" HorizontalAlignment="Center"
                        IsHitTestVisible="False">
                <TextBlock Text="⬇" FontSize="52" Foreground="#2a2a2a"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Sem ficheiro G-code" Foreground="#444"
                           FontSize="14" HorizontalAlignment="Center"
                           Margin="0,8,0,0"/>
                <TextBlock Text="Carregue um ficheiro na janela principal"
                           Foreground="#333" FontSize="10"
                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>

        <!-- ════════ LINHA 5: Rodapé ════════ -->
        <Border Grid.Row="5" Background="#141414"
                BorderBrush="#222" BorderThickness="0,1,0,0" Padding="8,0">
            <Grid>
                <TextBlock x:Name="TbStatus"
                           Text="Sem ficheiro" Foreground="#555"
                           FontSize="9" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="TbTaskTime" Text=""
                               Foreground="#555" FontSize="9"/>
                    <TextBlock x:Name="TbEta" Text=""
                               Foreground="#555" FontSize="9" Margin="8,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>

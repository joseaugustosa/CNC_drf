<UserControl x:Class="CNC_Drf.Views.GCodePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel>
        <ToolBar DockPanel.Dock="Top" Style="{StaticResource DarkToolBar}">
            <Button Style="{StaticResource SmallButton}" Click="BtnOpen_Click" Content="📂 Abrir G-code"/>
            <Separator/>
            <Button Style="{StaticResource SmallButton}" Click="BtnStart_Click"
                    Background="#40a02b" Foreground="White" Content="▶ Iniciar"/>
            <Button Style="{StaticResource SmallButton}" Click="BtnHold_Click"
                    Background="#df8e1d" Foreground="White" Content="⏸ Pausa"/>
            <Button Style="{StaticResource SmallButton}" Click="BtnAbort_Click"
                    Background="#d20f39" Foreground="White" Content="■ Abortar"/>
            <Separator/>
            <TextBlock VerticalAlignment="Center" Margin="6,0" Foreground="#6c7086" FontSize="11"
                       Text="{Binding FilePath, StringFormat='Ficheiro: {0}'}"/>
        </ToolBar>

        <ProgressBar DockPanel.Dock="Bottom" Style="{StaticResource DarkProgressBar}"
                     Value="{Binding Progress}" Maximum="100" Margin="0"/>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="140"/>
            </Grid.RowDefinitions>

            <!-- G-code listing -->
            <ListBox x:Name="GcodeList" Grid.Row="0" Style="{StaticResource DarkListBox}"
                     ItemsSource="{Binding Parser.Lines}"
                     DisplayMemberPath="Raw"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"/>

            <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch"
                          Background="{StaticResource BgSurface0}"/>

            <!-- Terminal log -->
            <ListBox Grid.Row="2" Style="{StaticResource DarkListBox}"
                     ItemsSource="{Binding Log}"
                     VirtualizingPanel.IsVirtualizing="True"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     x:Name="LogList"/>
        </Grid>
    </DockPanel>
</UserControl>

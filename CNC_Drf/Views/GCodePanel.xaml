<UserControl x:Class="CNC_Drf.Views.GCodePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#2b2b2b">
    <DockPanel>

        <!-- ── Toolbar superior ────────────────────────────────────────── -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                    Background="#222" Height="36">
            <Button Content="Open File" Click="BtnOpen_Click"
                    Width="60" Margin="2" Padding="2,1"
                    Background="#444" Foreground="White" BorderBrush="#666"
                    FontSize="10"/>
            <Button Content="Edit G-Code" Click="BtnEdit_Click"
                    Width="66" Margin="2" Padding="2,1"
                    Background="#444" Foreground="White" BorderBrush="#666"
                    FontSize="10"/>
            <Button Content="Last G-Code" Click="BtnLast_Click"
                    Width="66" Margin="2" Padding="2,1"
                    Background="#444" Foreground="White" BorderBrush="#666"
                    FontSize="10"/>
        </StackPanel>

        <!-- ── Status bar inferior ─────────────────────────────────────── -->
        <StackPanel DockPanel.Dock="Bottom" Background="#1a1a1a">
            <!-- Tempo da tarefa -->
            <StackPanel Orientation="Horizontal" Margin="4,2">
                <TextBlock Text="of the task: " Foreground="#aaa" FontSize="10"/>
                <TextBlock Text="{Binding TaskTime}" Foreground="#ccc" FontSize="10"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="4,0,4,2">
                <TextBlock Text="to completion:" Foreground="#aaa" FontSize="10"/>
            </StackPanel>
            <!-- Progresso -->
            <ProgressBar Value="{Binding Progress}" Maximum="100"
                         Height="6" Margin="4,0,4,2"
                         Background="#333" Foreground="#5ba85b"/>
            <!-- Status log última linha -->
            <TextBlock Text="{Binding StatusText}" Foreground="#88bb88"
                       FontSize="9" Margin="4,2" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- ── Botões Start / Pause / Stop ─────────────────────────────── -->
        <Grid DockPanel.Dock="Bottom" Height="64" Background="#222" Margin="0,2,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Start -->
            <Button Grid.Column="0" Click="BtnStart_Click" Margin="4"
                    Background="#2e7d32" BorderBrush="#43a047">
                <StackPanel HorizontalAlignment="Center">
                    <Ellipse Width="18" Height="18" Fill="#66bb6a" Margin="0,2,0,0"/>
                    <TextBlock Text="Start" Foreground="White" FontWeight="Bold"
                               FontSize="11" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Pause -->
            <Button Grid.Column="1" Click="BtnPause_Click" Margin="4"
                    Background="#444" BorderBrush="#666">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="⏸" FontSize="14" HorizontalAlignment="Center"
                               Foreground="#ccc" Margin="0,2,0,0"/>
                    <TextBlock Text="Pause" Foreground="#ccc" FontSize="11"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Stop -->
            <Button Grid.Column="2" Click="BtnStop_Click" Margin="4"
                    Background="#444" BorderBrush="#666">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="■" FontSize="14" HorizontalAlignment="Center"
                               Foreground="#e57373" Margin="0,2,0,0"/>
                    <TextBlock Text="Stop" Foreground="#e57373" FontSize="11"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- ── Lista G-code + drop zone ────────────────────────────────── -->
        <Grid>
            <ListBox x:Name="GcodeList"
                     ItemsSource="{Binding Parser.Lines}"
                     Background="#1e1e1e" Foreground="#c8c8c8"
                     BorderThickness="0"
                     FontFamily="Consolas" FontSize="11"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     AllowDrop="True" Drop="GcodeList_Drop"
                     DragOver="GcodeList_DragOver">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Raw}" FontFamily="Consolas" FontSize="11"
                                   Foreground="{Binding IsComment, Converter={StaticResource CommentColorConverter}}"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Drop here overlay quando vazio -->
            <StackPanel x:Name="DropOverlay" VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Visibility="{Binding FileName, Converter={StaticResource EmptyToVisibleConverter}}">
                <TextBlock Text="⬇" FontSize="32" Foreground="#555"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Drop here" Foreground="#555" FontSize="12"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </DockPanel>
</UserControl>

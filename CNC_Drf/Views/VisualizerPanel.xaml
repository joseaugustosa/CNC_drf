<UserControl x:Class="CNC_Drf.Views.VisualizerPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="http://helix-toolkit.org/wpf">
    <DockPanel Background="#3c3c3c">

        <!-- ── Barra de zoom / vistas (fundo) ──────────────────────────── -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    Background="#222" Height="38" HorizontalAlignment="Center">
            <Button Content="+" Width="36" Height="30" Margin="3,4" FontSize="16" FontWeight="Bold"
                    Click="BtnZoomIn_Click"
                    Background="#444" Foreground="White" BorderBrush="#666" ToolTip="Zoom In"/>
            <Button Content="−" Width="36" Height="30" Margin="3,4" FontSize="16" FontWeight="Bold"
                    Click="BtnZoomOut_Click"
                    Background="#444" Foreground="White" BorderBrush="#666" ToolTip="Zoom Out"/>
            <Button Content="1:1" Width="40" Height="30" Margin="3,4" FontSize="11" FontWeight="Bold"
                    Click="BtnZoom1_Click"
                    Background="#444" Foreground="White" BorderBrush="#666" ToolTip="Zoom 1:1"/>
            <Button Content="x10" Width="40" Height="30" Margin="3,4" FontSize="11" FontWeight="Bold"
                    Click="BtnZoomFit_Click"
                    Background="#444" Foreground="White" BorderBrush="#666" ToolTip="Fit"/>
            <Separator Width="1" Background="#555" Margin="4,6"/>
            <Button Content="XY" Width="32" Height="30" Margin="3,4" FontSize="10" FontWeight="Bold"
                    Click="BtnViewXY_Click" Background="#444" Foreground="#a5d6a7" BorderBrush="#666"/>
            <Button Content="XZ" Width="32" Height="30" Margin="3,4" FontSize="10" FontWeight="Bold"
                    Click="BtnViewXZ_Click" Background="#444" Foreground="#90caf9" BorderBrush="#666"/>
            <Button Content="ZY" Width="32" Height="30" Margin="3,4" FontSize="10" FontWeight="Bold"
                    Click="BtnViewZY_Click" Background="#444" Foreground="#f48fb1" BorderBrush="#666"/>
            <Button Content="3D" Width="32" Height="30" Margin="3,4" FontSize="10" FontWeight="Bold"
                    Click="BtnView3D_Click" Background="#555" Foreground="White" BorderBrush="#888"/>
        </StackPanel>

        <!-- ── Viewport 3D ─────────────────────────────────────────────── -->
        <h:HelixViewport3D x:Name="Viewport"
                           Background="#3c3c3c"
                           ShowCoordinateSystem="True"
                           CoordinateSystemHorizontalPosition="Right"
                           CoordinateSystemVerticalPosition="Top"
                           IsHeadLightEnabled="True"
                           IsZoomEnabled="True"
                           CameraRotationMode="Trackball"
                           MouseWheel="Viewport_MouseWheel">

            <h:HelixViewport3D.DefaultCamera>
                <PerspectiveCamera FieldOfView="45"
                                   Position="0,0,300"
                                   LookDirection="0,0,-1"
                                   UpDirection="0,1,0"/>
            </h:HelixViewport3D.DefaultCamera>

            <!-- Grid XY -->
            <h:GridLinesVisual3D x:Name="GridXY"
                                 Width="400" Length="400"
                                 MajorDistance="50" MinorDistance="10"
                                 Thickness="0.4">
                <h:GridLinesVisual3D.Material>
                    <DiffuseMaterial>
                        <DiffuseMaterial.Brush>
                            <SolidColorBrush Color="#667799" Opacity="0.3"/>
                        </DiffuseMaterial.Brush>
                    </DiffuseMaterial>
                </h:GridLinesVisual3D.Material>
            </h:GridLinesVisual3D>

            <!-- Percurso rápido (G0) -->
            <h:LinesVisual3D x:Name="PathRapid"  Color="#4fc3f7" Thickness="1.0"/>
            <!-- Percurso de corte (G1) -->
            <h:LinesVisual3D x:Name="PathCut"    Color="#ffeb3b" Thickness="1.8"/>
            <!-- Linha atual em destaque -->
            <h:LinesVisual3D x:Name="PathCurrent" Color="#ffffff" Thickness="3.0"/>

            <!-- Posição da ferramenta -->
            <h:SphereVisual3D x:Name="ToolMarker" Radius="3" Visible="False">
                <h:SphereVisual3D.Fill>
                    <SolidColorBrush Color="#ff5252"/>
                </h:SphereVisual3D.Fill>
            </h:SphereVisual3D>

            <!-- Origem (home) -->
            <h:SphereVisual3D x:Name="HomeMarker" Radius="2" Center="0,0,0">
                <h:SphereVisual3D.Fill>
                    <SolidColorBrush Color="#69f0ae"/>
                </h:SphereVisual3D.Fill>
            </h:SphereVisual3D>
        </h:HelixViewport3D>
    </DockPanel>
</UserControl>

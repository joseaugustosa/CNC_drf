<UserControl x:Class="CNC_Drf.Views.VisualizerPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="http://helix-toolkit.org/wpf">
    <DockPanel>
        <ToolBar DockPanel.Dock="Top" Style="{StaticResource DarkToolBar}">
            <Button Style="{StaticResource SmallButton}" Click="BtnFit_Click" Content="⊡ Ajustar vista"/>
            <Button Style="{StaticResource SmallButton}" Click="BtnZoomIn_Click"  Content="Zoom +"/>
            <Button Style="{StaticResource SmallButton}" Click="BtnZoomOut_Click" Content="Zoom -"/>
            <Separator/>
            <ToggleButton x:Name="BtnXY" Content="XY" Style="{StaticResource DarkToggleButton}"
                          IsChecked="True" Click="BtnPlane_Click"/>
            <ToggleButton x:Name="BtnXZ" Content="XZ" Style="{StaticResource DarkToggleButton}"
                          Click="BtnPlane_Click"/>
            <ToggleButton x:Name="BtnZY" Content="ZY" Style="{StaticResource DarkToggleButton}"
                          Click="BtnPlane_Click"/>
            <Separator/>
            <TextBlock VerticalAlignment="Center" Foreground="#6c7086" FontSize="11" Margin="4,0"
                       Text="Arrastar=órbita · Ctrl+Arrastar=pan · Roda=zoom"/>
        </ToolBar>

        <h:HelixViewport3D x:Name="Viewport"
                           Background="#11111b"
                           ShowCoordinateSystem="True"
                           CoordinateSystemHorizontalPosition="Right"
                           CoordinateSystemVerticalPosition="Top"
                           IsHeadLightEnabled="True"
                           IsZoomEnabled="True"
                           CameraRotationMode="Trackball"
                           MouseWheel="Viewport_MouseWheel">

            <h:HelixViewport3D.DefaultCamera>
                <PerspectiveCamera FieldOfView="45"
                                   Position="150,150,150"
                                   LookDirection="-1,-1,-1"
                                   UpDirection="0,0,1"/>
            </h:HelixViewport3D.DefaultCamera>

            <h:GridLinesVisual3D x:Name="GridXY" Width="300" Length="300"
                                 MajorDistance="50" MinorDistance="10" Thickness="0.3">
                <h:GridLinesVisual3D.Material>
                    <DiffuseMaterial>
                        <DiffuseMaterial.Brush>
                            <SolidColorBrush Color="#444466" Opacity="0.15"/>
                        </DiffuseMaterial.Brush>
                    </DiffuseMaterial>
                </h:GridLinesVisual3D.Material>
            </h:GridLinesVisual3D>

            <h:LinesVisual3D x:Name="PathRapid"  Color="#b4befe" Thickness="1.2"/>
            <h:LinesVisual3D x:Name="PathCut"    Color="#f9e2af" Thickness="2.0"/>
            <h:SphereVisual3D x:Name="ToolMarker" Radius="2.5" Visible="False">
                <h:SphereVisual3D.Fill>
                    <SolidColorBrush Color="#ff6b6b"/>
                </h:SphereVisual3D.Fill>
            </h:SphereVisual3D>
        </h:HelixViewport3D>
    </DockPanel>
</UserControl>

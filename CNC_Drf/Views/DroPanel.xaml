<UserControl x:Class="CNC_Drf.Views.DroPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <GroupBox Header="Posição (DRO)" Style="{StaticResource DarkGroupBox}">
        <Grid Margin="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Label Grid.Row="0" Grid.Column="0" Content="X" Foreground="#f38ba8" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource DroDisplay}"
                       Text="{Binding PosX, StringFormat={}{0:F3}}"/>
            <Button Grid.Row="0" Grid.Column="2" Content="Zero X" Style="{StaticResource SmallButton}" Margin="4,2"
                    Command="{Binding SendCommandCommand}" CommandParameter="G92 X0"/>

            <Label Grid.Row="1" Grid.Column="0" Content="Y" Foreground="#a6e3a1" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource DroDisplay}"
                       Text="{Binding PosY, StringFormat={}{0:F3}}"/>
            <Button Grid.Row="1" Grid.Column="2" Content="Zero Y" Style="{StaticResource SmallButton}" Margin="4,2"
                    Command="{Binding SendCommandCommand}" CommandParameter="G92 Y0"/>

            <Label Grid.Row="2" Grid.Column="0" Content="Z" Foreground="#89b4fa" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource DroDisplay}"
                       Text="{Binding PosZ, StringFormat={}{0:F3}}"/>
            <Button Grid.Row="2" Grid.Column="2" Content="Zero Z" Style="{StaticResource SmallButton}" Margin="4,2"
                    Command="{Binding SendCommandCommand}" CommandParameter="G92 Z0"/>

            <Label Grid.Row="3" Grid.Column="0" Content="A" Foreground="#f9e2af" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource DroDisplay}"
                       Text="{Binding PosA, StringFormat={}{0:F3}}"/>
            <Button Grid.Row="3" Grid.Column="2" Content="Zero A" Style="{StaticResource SmallButton}" Margin="4,2"
                    Command="{Binding SendCommandCommand}" CommandParameter="G92 A0"/>
        </Grid>
    </GroupBox>
</UserControl>

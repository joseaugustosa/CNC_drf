{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug CNC_Drf",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build CNC_Drf",
            "program": "${workspaceFolder}/CNC_Drf/bin/Debug/net8.0-windows/CNC_Drf.exe",
            "args": [],
            "cwd": "${workspaceFolder}/CNC_Drf",
            "stopAtEntry": false,
            "console": "internalConsole",
            "justMyCode": true,
            "requireExactSource": false,
            "enableStepFiltering": true,
            "env": {
                "DOTNET_ENVIRONMENT": "Development"
            }
        }
    ]
}
